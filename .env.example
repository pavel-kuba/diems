# Copy this file to .env.local and fill in your keys.

# Resend API key — loaded server-side only, never exposed to the browser.
# Get one at https://resend.com/api-keys (starts with re_).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- Follow-up sequence -----------------------------------------------
# Host used in outbound Message-IDs so follow-ups thread under the original.
# Should be a Resend-verified domain (keeps DKIM aligned). If unset, the From
# address's domain is used. (Replies are tracked manually in the UI.)
SENDING_DOMAIN=mail.yourdomain.com

# --- Contact research (research-contacts skill) -----------------------
# Hunter.io — finds + verifies decision-maker emails at a company domain.
# Get one at https://hunter.io/api-keys
HUNTER_API_KEY=

# Email verification provider used by scripts/verify-email.mjs.
# One of: hunter (default, reuses HUNTER_API_KEY) | neverbounce | zerobounce
VERIFIER_PROVIDER=hunter
# Key for the dedicated verifier (only needed if VERIFIER_PROVIDER != hunter).
VERIFIER_API_KEY=
